# ── Tollgate ────────────────────────────────
TOLLGATE_PORT=7777
ADMIN_USER=andrew
ADMIN_EMAIL=you@example.com
# Generate: htpasswd -bnBC 10 "" yourpassword | tr -d ':\n'
ADMIN_PASSWORD_HASH=$2b$10$CHANGE_ME

# ── Host ─────────────────────────────────────
HOST_DOMAIN=localhost
TZ=Europe/Moscow
AUDIT_LOG_DIR=./logs

# ── Patchbook (RAG) ──────────────────────────
OLLAMA_HOST=http://host.docker.internal:11434
LLM_MODEL=qwen2.5:1.5b
CHUNK_SIZE=400
CHUNK_OVERLAP=80
N_RESULTS=5

# ── n8n ──────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme
N8N_AUTH_ACTIVE=true

# ── Zabbix ───────────────────────────────────
ZABBIX_DB_PASSWORD=changeme
